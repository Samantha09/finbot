{
  "gateway": {
    "mode": "local"
  },
  "models": {
    "providers": {
      "minimax": {
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "api": "anthropic-messages",
        "authHeader": true,
        "apiKey": "${MINIMAX_API_KEY}",
        "models": [
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7",
            "reasoning": true,
            "contextWindow": 204800,
            "maxTokens": 131072
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "minimax/MiniMax-M2.7"
    },
    "list": [
      {
        "id": "finbot",
        "default": true,
        "tools": {
          "deny": ["write", "edit", "apply_patch", "exec", "process"]
        }
      }
    ]
  }
}
